# Copy this file to ".env" and fill in your bot token.
DISCORD_TOKEN=your-bot-token-here

# Optional tuning (defaults shown):
# How often to poll the TD2 API, in seconds.
POLL_INTERVAL=30
# How many consecutive polls a station must be absent before notifying.
MISS_THRESHOLD=2
# Count a station as occupied only when isOnline == 1.
REQUIRE_IS_ONLINE=true
